# Claude Agent Starter — 环境变量配置
# 复制此文件为 .env 并填入真实值

# ── 方案一：官方 Anthropic 直连（推荐） ──────────────────
# ACTIVE_PROVIDER=anthropic_official
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# ANTHROPIC_BASE_URL=                   # 可选，留空用默认
# ANTHROPIC_CUSTOM_HEADERS=             # 可选，自定义请求头

# ── 方案二：AI 网关（需兼容 Anthropic Messages API） ────
# ACTIVE_PROVIDER=ai_gate
# AI_GATE_API_KEY=your_gateway_key
# AI_GATE_BASE_URL=https://your-gateway.example.com
# AI_GATE_MODEL=anthropic/claude-sonnet-4-6
# AI_GATE_SMALL_MODEL=anthropic/claude-haiku-4-5

# ── 通用配置 ─────────────────────────────────────────────
# CLAUDE_MODEL=claude-sonnet-4-6        # 可选，覆盖默认模型
# ANTHROPIC_SMALL_FAST_MODEL=           # 可选，覆盖 CLI 内部小模型

# ── 前提条件 ─────────────────────────────────────────────
# Claude Code CLI 必须已安装：
#   npm install -g @anthropic-ai/claude-code
#   claude --version
